# Copie para .env na raiz do projeto ou use: docker compose --env-file docker/.env
# Valores alinhados ao docker-compose.yml (serviço postgres)

APP_NAME="Bolso Planejado"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=divida_zero
DB_USERNAME=divida_zero
DB_PASSWORD=divida_zero_secret

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
